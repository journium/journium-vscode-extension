{
  "Funnel Tracker": {
    "scope": "yaml",
    "prefix": "jt-funnel",
    "description": "Journium v0Beta Insight Tracker — funnel analysis",
    "body": [
      "apiVersion: journium.app/v0Beta",
      "kind: InsightTracker",
      "metadata:",
      "  name: ${1:funnel-tracker}",
      "  appInstanceId: ${2:your-app-instance-id}",
      "spec:",
      "  type: LLM",
      "  trigger:",
      "    mode: automatic",
      "    schedule: weekly",
      "  window:",
      "    period: last_7d",
      "  analysis:",
      "    type: funnel",
      "    steps:",
      "      - event: ${3:first-event}",
      "        label: ${4:Step 1}",
      "      - event: ${5:second-event}",
      "        label: ${6:Step 2}",
      "      - event: ${7:third-event}",
      "        label: ${8:Step 3}",
      "  llm:",
      "    promptTemplate: >-",
      "      ${9:Analyze the funnel performance for {{windowPeriod}}. Highlight the step with the biggest drop-off and suggest improvements.}"
    ]
  },

  "Retention Tracker": {
    "scope": "yaml",
    "prefix": "jt-retention",
    "description": "Journium v0Beta Insight Tracker — retention analysis",
    "body": [
      "apiVersion: journium.app/v0Beta",
      "kind: InsightTracker",
      "metadata:",
      "  name: ${1:retention-tracker}",
      "  appInstanceId: ${2:your-app-instance-id}",
      "spec:",
      "  type: LLM",
      "  trigger:",
      "    mode: automatic",
      "    schedule: weekly",
      "  window:",
      "    period: last_30d",
      "  analysis:",
      "    type: retention",
      "    cohortEvent: ${3:user-signed-up}",
      "    retentionEvent: ${4:user-active}",
      "    cohortPeriod: week",
      "    intervals: [1, 2, 4, 8]",
      "  llm:",
      "    promptTemplate: >-",
      "      ${5:Analyze retention for cohorts in {{windowPeriod}}. Identify trends and cohorts with the highest and lowest retention.}"
    ]
  },

  "Activation Tracker": {
    "scope": "yaml",
    "prefix": "jt-activation",
    "description": "Journium v0Beta Insight Tracker — activation analysis",
    "body": [
      "apiVersion: journium.app/v0Beta",
      "kind: InsightTracker",
      "metadata:",
      "  name: ${1:activation-tracker}",
      "  appInstanceId: ${2:your-app-instance-id}",
      "spec:",
      "  type: LLM",
      "  trigger:",
      "    mode: automatic",
      "    schedule: weekly",
      "  window:",
      "    period: last_7d",
      "  analysis:",
      "    type: activation",
      "    startEvent: ${3:user-signed-up}",
      "    ahaEvent: ${4:aha-moment-event}",
      "    activationWindow: ${5:48h}",
      "  llm:",
      "    promptTemplate: >-",
      "      ${6:Analyze activation rates for {{windowPeriod}}. How many users reached the aha moment within the activation window?}"
    ]
  },

  "Churn Tracker": {
    "scope": "yaml",
    "prefix": "jt-churn",
    "description": "Journium v0Beta Insight Tracker — churn analysis",
    "body": [
      "apiVersion: journium.app/v0Beta",
      "kind: InsightTracker",
      "metadata:",
      "  name: ${1:churn-tracker}",
      "  appInstanceId: ${2:your-app-instance-id}",
      "spec:",
      "  type: LLM",
      "  trigger:",
      "    mode: automatic",
      "    schedule: weekly",
      "  window:",
      "    period: last_30d",
      "  analysis:",
      "    type: churn",
      "    activeEvent: ${3:user-active}",
      "    inactivityThreshold: ${4:14d}",
      "    lookbackPeriod: 30d",
      "  llm:",
      "    promptTemplate: >-",
      "      ${5:Analyze churn risk for {{windowPeriod}}. How many users are at risk? What segments show the highest churn?}"
    ]
  },

  "Feature Adoption Tracker": {
    "scope": "yaml",
    "prefix": "jt-feature-adoption",
    "description": "Journium v0Beta Insight Tracker — feature adoption analysis",
    "body": [
      "apiVersion: journium.app/v0Beta",
      "kind: InsightTracker",
      "metadata:",
      "  name: ${1:feature-adoption-tracker}",
      "  appInstanceId: ${2:your-app-instance-id}",
      "spec:",
      "  type: LLM",
      "  trigger:",
      "    mode: automatic",
      "    schedule: weekly",
      "  window:",
      "    period: last_14d",
      "  analysis:",
      "    type: featureAdoption",
      "    featureEvents:",
      "      - event: ${3:feature-used}",
      "        label: ${4:Feature Name}",
      "    activeUserBaseline:",
      "      event: ${5:user-active}",
      "  llm:",
      "    promptTemplate: >-",
      "      ${6:Analyze feature adoption for {{windowPeriod}}. What percentage of active users adopted the feature? Is adoption growing?}"
    ]
  },

  "Anomaly Tracker": {
    "scope": "yaml",
    "prefix": "jt-anomaly",
    "description": "Journium v0Beta Insight Tracker — anomaly detection analysis",
    "body": [
      "apiVersion: journium.app/v0Beta",
      "kind: InsightTracker",
      "metadata:",
      "  name: ${1:anomaly-tracker}",
      "  appInstanceId: ${2:your-app-instance-id}",
      "spec:",
      "  type: LLM",
      "  trigger:",
      "    mode: automatic",
      "    schedule: daily",
      "  window:",
      "    period: last_7d",
      "  analysis:",
      "    type: anomaly",
      "    metrics:",
      "      - event: ${3:tracked-event}",
      "        aggregation: count",
      "        groupBy: day",
      "        label: ${4:Metric Label}",
      "    baseline:",
      "      type: rolling_average",
      "      windowDays: 14",
      "    threshold:",
      "      stdDeviations: 2.0",
      "  llm:",
      "    promptTemplate: >-",
      "      ${5:Analyze anomalies in {{windowPeriod}}. Describe any significant deviations and their potential causes.}"
    ]
  },

  "Conversion Tracker": {
    "scope": "yaml",
    "prefix": "jt-conversion",
    "description": "Journium v0Beta Insight Tracker — conversion rate analysis",
    "body": [
      "apiVersion: journium.app/v0Beta",
      "kind: InsightTracker",
      "metadata:",
      "  name: ${1:conversion-tracker}",
      "  appInstanceId: ${2:your-app-instance-id}",
      "spec:",
      "  type: LLM",
      "  trigger:",
      "    mode: automatic",
      "    schedule: weekly",
      "  window:",
      "    period: last_7d",
      "  analysis:",
      "    type: conversion",
      "    numeratorEvent: ${3:converted-event}",
      "    denominatorEvent: ${4:entry-event}",
      "    conversionWindow: ${5:48h}",
      "    compareWindow: previous_period",
      "  llm:",
      "    promptTemplate: >-",
      "      ${6:Analyze the conversion rate for {{windowPeriod}}. How does it compare to the previous period?}"
    ]
  },

  "Cohort Tracker": {
    "scope": "yaml",
    "prefix": "jt-cohort",
    "description": "Journium v0Beta Insight Tracker — cohort analysis",
    "body": [
      "apiVersion: journium.app/v0Beta",
      "kind: InsightTracker",
      "metadata:",
      "  name: ${1:cohort-tracker}",
      "  appInstanceId: ${2:your-app-instance-id}",
      "spec:",
      "  type: LLM",
      "  trigger:",
      "    mode: automatic",
      "    schedule: weekly",
      "  window:",
      "    period: last_30d",
      "  analysis:",
      "    type: cohort",
      "    cohortDefinition:",
      "      firstEvent: ${3:user-signed-up}",
      "      period: week",
      "    metric:",
      "      event: ${4:value-event}",
      "      aggregation: count",
      "  llm:",
      "    promptTemplate: >-",
      "      ${5:Analyze the cohort data for {{windowPeriod}}. Compare how different cohorts perform on the key metric.}"
    ]
  }
}
